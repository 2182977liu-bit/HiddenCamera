<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="24dp" />

        <!-- 摄像头选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_camera"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <RadioGroup
            android:id="@+id/rgCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_back"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbFront"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_front" />

        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- 视频分辨率 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/video_resolution_label"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <Spinner
            android:id="@+id/spinnerResolution"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- 帧率选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/fps_label"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <Spinner
            android:id="@+id/spinnerFps"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- 预览模式 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preview_mode_label"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <RadioGroup
            android:id="@+id/rgPreviewMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbPreviewLive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview_mode_live"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbPreviewStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview_mode_status" />

            <RadioButton
                android:id="@+id/rbPreviewBlank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview_mode_blank" />

        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- 通知栏快捷按钮 -->
        <Switch
            android:id="@+id/switchNotificationAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/notification_action_label"
            android:textSize="16sp"
            android:textColor="#333333" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/notification_action_desc"
            android:textSize="13sp"
            android:textColor="#999999"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- 桌面快捷方式 -->
        <Switch
            android:id="@+id/switchShortcut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shortcut_enabled_label"
            android:textSize="16sp"
            android:textColor="#333333" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shortcut_enabled_desc"
            android:textSize="13sp"
            android:textColor="#999999"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateShortcut"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="创建桌面快捷图标"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
